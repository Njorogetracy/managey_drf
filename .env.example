# =============================================================================
# MANAGEY BACKEND - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in real values.
# The .env file is in .gitignore and will NEVER be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO CORE SETTINGS
# -----------------------------------------------------------------------------

# Secret key - generate a random 50+ character string
# You can generate one at: https://djecrety.ir/
SECRET_KEY=replace-with-a-long-random-string-at-least-50-characters

# Debug mode - MUST be False in production, can be True locally
DEBUG=True

# Set this to "1" only for local development
# Enables SQLite database and session auth instead of JWT
DEV=1

# -----------------------------------------------------------------------------
# HOSTING & DOMAINS
# -----------------------------------------------------------------------------

# Domains Django will respond to (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend domains allowed to make CORS requests (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Trusted origins for CSRF protection (comma-separated)
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# DATABASE - Neon PostgreSQL (free tier, no credit card)
# -----------------------------------------------------------------------------
# Get your free Neon database at: https://neon.tech
# Used in production. Local dev uses SQLite (set DEV=1 above).
#
# Format: postgres://username:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://username:password@ep-xxx.neon.tech/managey_db?sslmode=require

# -----------------------------------------------------------------------------
# FILE STORAGE - Cloudinary (free tier, no credit card)
# -----------------------------------------------------------------------------
# Get yours at: https://cloudinary.com (free tier: 25 credits/month)
# Find these on the Cloudinary Dashboard under "Product Environment Credentials"
# Only needed in production — local dev uses the filesystem (set DEV=1 above).
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
